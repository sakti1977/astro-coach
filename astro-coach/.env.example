# ─── Anthropic ────────────────────────────────────────────────────────────────
# Required — get from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ─── Ephemeris service ────────────────────────────────────────────────────────
# URL of the Python ephemeris microservice
# Local dev: http://localhost:8000
# Production: set to your Railway/Render deployment URL
EPHEMERIS_SERVICE_URL=http://localhost:8000

# CORS origins allowed by the Python service — set this in Railway → Variables.
# Comma-separated list. Restrict to your Vercel domain in production.
# Example: https://your-app.vercel.app
# Omit (or leave as default) in local dev; the service defaults to localhost.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Required — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-random-secret-here

# Required — base URL of your app (no trailing slash)
# Local dev: http://localhost:3000
# Production: https://your-app.vercel.app
NEXTAUTH_URL=http://localhost:3000

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Required for authentication and data persistence
# Get from: https://app.supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Phone OTP (via Supabase) ─────────────────────────────────────────────────
# Enable phone auth in Supabase Dashboard:
#   Authentication → Providers → Phone → Enable
#   Then configure an SMS provider (Twilio recommended):
#     Authentication → Providers → Phone → Twilio
#   Required Twilio settings (set in Supabase Dashboard, NOT here):
#     - Account SID
#     - Auth Token
#     - Message Service SID (or From number)
# No extra env vars needed here — Supabase manages the SMS provider config.
